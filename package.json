{
  "name": "amsterdam-pools",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node --watch --import tsx apps/api/src/server.ts",
    "mobile": "npm --workspace @amsterdam-pools/mobile run start",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
